generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  youtube
  pdf
  doc
  image
  text
}

enum ExtractionStatus {
  processing
  completed
  failed
}


model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  hasOnboarded Boolean @default(false)

  accounts  Account[]
  sessions  Session[]
  notebooks Notebook[]
  characters Character[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notebook {
  id          String   @id @default(cuid())
  name        String
  description String?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  characterId String?
  character   Character? @relation(fields: [characterId], references: [id])

  messages  Message[]

  sources NotebookSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Message {
  id          String @id @default(cuid())

  role        String   // user | assistant | system
  content     String

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  notebookId String
  notebook   Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  @@index([notebookId, createdAt])
}

model Character {
  id            String   @id @default(cuid())

  name          String
  role          String
  systemPrompt  String

  expertise     String?
  personality   String?
  speakingStyle String?
  goal          String?

  avatarUrl     String?
  messages      Message[]
  notebooks     Notebook[]

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model SourceChunk {
  id          String @id @default(cuid())

  content     String
  embedding   Json
  chunkIndex  Int

  sourceId    String
  source      ExtractedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([sourceId])
}

model ExtractedSource {
  id          String   @id @default(cuid())

  sourceKey   String   @unique
  type        SourceType

  title       String
  content     String?

  thumbnail   String?
  metadata    Json?

  status      ExtractionStatus @default(processing)

  chunks      SourceChunk[]
  notebooks   NotebookSource[]

  createdAt   DateTime @default(now())
}

model NotebookSource {
  id          String @id @default(cuid())

  notebookId  String
  sourceId    String

  fileUrl     String?

  notebook    Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  source      ExtractedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([notebookId, sourceId])
}